# Local development defaults. Never reuse these secrets in production.
APP_ENV=development
DATABASE_URL=sqlite:///./.aisec-data/armor.db
DATABASE_AUTO_CREATE=true
SEED_DEMO_USER=true
API_KEY_PEPPER=dev-api-key-pepper-change-in-production
API_KEY=dev-key-change-in-production
MCP_ALLOW_ANONYMOUS=false
MCP_API_KEY_RATE_LIMIT_PER_MIN=120
MCP_ANONYMOUS_RATE_LIMIT_PER_MIN=10
# Remote OpenAI-compatible AI server (vLLM harness in docker-compose.ai.yml).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=prewise-security-v1
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOKENS=500
# Optional contextual specialists. Missing/disabled adapters degrade safely.
ADAPTER_REGISTRY_ENABLED=true
ADAPTER_MANIFEST_PATH=server/adapters/manifest.json
ADAPTER_BASE_URL=
ADAPTER_API_KEY=
ADAPTER_TIMEOUT_SECONDS=15
ADAPTER_MAX_RISK_CONTRIBUTION=0.25
PHONE_INTELLIGENCE_URL=
# URL intelligence used by Balanced/Deep scans. All remote threat sources are opt-in.
IP_GEOLOCATION_ENABLED=true
IP2LOCATION_API_KEY=
IP_GEOLOCATION_TIMEOUT_SECONDS=3
HUDSON_ROCK_API_KEY=
PHISHTANK_ENABLED=false
PHISHTANK_API_KEY=
IPQS_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
APIVOID_API_KEY=
PHISHDESTROY_ENABLED=false
URLVET_ENABLED=false
URLVET_API_URL=http://127.0.0.1:8080
URLVET_TIMEOUT_SECONDS=12
MISP_ENABLED=false
MISP_BASE_URL=
MISP_API_KEY=
MISP_VERIFY_TLS=true

# Optional bounded local feeds and multi-machine IOC consensus.
THREAT_FEED_SCHEDULER_ENABLED=false
THREAT_FEED_SCHEDULER_INTERVAL_MINUTES=60
THREAT_FEED_PHISHTANK_ENABLED=false
THREAT_FEED_PHISHTANK_APP_KEY=
THREAT_FEED_OPENPHISH_ENABLED=false
THREAT_FEED_URLHAUS_ENABLED=false
THREAT_FEED_URLHAUS_AUTH_KEY=
THREAT_FEED_PHISHING_DATABASE_PATH=.aisec-data/Phishing.Database
TELEMETRY_SENSOR_PEPPER=dev-telemetry-pepper-change-in-production
TELEMETRY_RETENTION_DAYS=30
TELEMETRY_CONSENSUS_WINDOW_DAYS=14
TELEMETRY_MIN_INDEPENDENT_SENSORS=2
# Legacy local Ollama fallback when LLM_BASE_URL is empty.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
IP2WHOIS_API_KEY=
WHOISXML_API_KEY=
CORS_ALLOW_ORIGINS=["https://prewise.site","https://www.prewise.site","http://localhost:3000","http://127.0.0.1:3000"]

# SePay webhook + dynamic VietQR image. Account details are used only to generate the public QR.
# Prefer HMAC secret received from SePay; do not commit or expose it.
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_ACCOUNT=100876855977
SEPAY_BANK_NAME=VietinBank
SEPAY_ACCOUNT_NAME=
SEPAY_QR_BASE_URL=https://vietqr.app/img
SEPAY_PAYMENT_EXPIRY_MINUTES=30
SANDBOX_CREDIT_PRICE_VND=15000
SANDBOX_SESSION_MINUTES=10

# AWS disposable Windows sandbox. Prefer an account dedicated to untrusted workloads.
AWS_REGION=ap-southeast-1
AWS_SANDBOX_AMI_ID=
AWS_SANDBOX_INSTANCE_TYPE=t3.large
AWS_SANDBOX_SUBNET_ID=
AWS_SANDBOX_SECURITY_GROUP_ID=
AWS_SANDBOX_KEY_NAME=
AWS_SANDBOX_REMOTE_PORT=8443

# Production must set these values or the services will fail fast:
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://...
# DATABASE_AUTO_CREATE=false
# SEED_DEMO_USER=false
# API_KEY_PEPPER=<at-least-32-random-bytes>
# API_KEY=<random-secret>
# MCP_ALLOW_ANONYMOUS=false
# MCP_API_KEY_RATE_LIMIT_PER_MIN=120
# Anonymous/free server-side quotas
ANONYMOUS_DAILY_AI_CREDIT_LIMIT=5
ANONYMOUS_DAILY_DEEP_SCAN_LIMIT=1
# Email attachment security (ClamAV should be on a private network only).
CLAMAV_HOST=
CLAMAV_PORT=3310
ATTACHMENT_SCAN_TIMEOUT_SECONDS=10
TESSERACT_EXECUTABLE=
TESSERACT_LANGUAGES=vie+eng
ATTACHMENT_OCR_TIMEOUT_SECONDS=12
EMAIL_ATTACHMENT_SANDBOX_ENABLED=false
EMAIL_ATTACHMENT_ACTIVE_SCAN_LIMIT=12
EMAIL_OCR_IMAGE_LIMIT=5
EMAIL_SANDBOX_FILE_LIMIT=1
EMAIL_ATTACHMENT_BUDGET_SECONDS=35
EMAIL_ANALYSIS_TIMEOUT_SECONDS=90
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/v1/integrations/gmail/callback
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_TOKEN_ENCRYPTION_KEYS=
GMAIL_WEB_RETURN_URL=http://localhost:3000/analyze?gmail=connected
GMAIL_API_TIMEOUT_SECONDS=12
