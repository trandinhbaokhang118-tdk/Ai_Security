+def test_sms_sender_abuse_is_high_evidence_but_not_a_standalone_block() -> None:
+    result = assess_text_risk(
+        "Chào bạn, đây là một tin nhắn bình thường.",
+        "sms",
+        {"sender_abuse_confirmed": True},
+    )
+    assert "S-ID-02" in features(result)
