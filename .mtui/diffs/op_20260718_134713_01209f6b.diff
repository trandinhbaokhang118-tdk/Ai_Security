+def normalize_rendered_content(content: str) -> str:
+    """Sửa các tổ hợp thời hạn không tự nhiên do template và placeholder cùng chứa giới từ."""
+    for bad, replacement in BAD_DEADLINE_PHRASES.items():
+        content = content.replace(bad, replacement)
+        content = content.replace(v3.strip_accents(bad), v3.strip_accents(replacement))
+    return " ".join(content.split())
