+    def _query_certificates(self, domain: str) -> tuple[list[dict[str, Any]] | None, str | None]:
+        try:
+            response = httpx.get(
+                "https://crt.sh/",
+                params={"q": f"%.{domain}", "output": "json"},
+                timeout=max(self.timeout_seconds, 8.0),
+                headers={"User-Agent": "Prewise/0.2"},
+            )
