# Local development defaults. Never reuse these secrets in production.
APP_ENV=development
DATABASE_URL=sqlite:///./.aisec-data/armor.db
DATABASE_AUTO_CREATE=true
SEED_DEMO_USER=true
API_KEY_PEPPER=dev-api-key-pepper-change-in-production
API_KEY=dev-key-change-in-production
MCP_ALLOW_ANONYMOUS=false
MCP_API_KEY_RATE_LIMIT_PER_MIN=120
MCP_ANONYMOUS_RATE_LIMIT_PER_MIN=10
OLLAMA_BASE_URL=http://localhost:11434
IP2WHOIS_API_KEY=
WHOISXML_API_KEY=

# Basic URL result fields: public-IP city/country, ASN and network provider.
# IP2Location permits a limited keyless tier; configure a key for sustained use.
IP_GEOLOCATION_ENABLED=true
IP2LOCATION_API_KEY=
IP_GEOLOCATION_TIMEOUT_SECONDS=3
IP_GEOLOCATION_CACHE_TTL_SECONDS=21600

# Optional URL threat-intelligence providers. Keep disabled until privacy/licensing
# has been reviewed; a provider no-hit is never treated as proof that a URL is safe.
HUDSON_ROCK_API_KEY=
PHISHTANK_ENABLED=false
PHISHTANK_API_KEY=
IPQS_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
APIVOID_API_KEY=
PHISHDESTROY_ENABLED=false
URLVET_ENABLED=false
URLVET_API_URL=http://127.0.0.1:8080
URLVET_TIMEOUT_SECONDS=12

# Local threat-feed collector. Enable only after accepting provider terms and
# configuring required keys. The scheduler checks hourly; OpenPhish is fetched at
# most every 12 hours because that is the Community feed update frequency.
THREAT_FEED_SCHEDULER_ENABLED=false
THREAT_FEED_SCHEDULER_INTERVAL_MINUTES=60
THREAT_FEED_PHISHTANK_ENABLED=false
THREAT_FEED_PHISHTANK_URL=http://data.phishtank.com/data/online-valid.csv.gz
THREAT_FEED_PHISHTANK_APP_KEY=
THREAT_FEED_OPENPHISH_ENABLED=false
THREAT_FEED_OPENPHISH_URL=https://raw.githubusercontent.com/openphish/public_feed/refs/heads/main/feed.txt
THREAT_FEED_OPENPHISH_INTERVAL_HOURS=12
THREAT_FEED_URLHAUS_ENABLED=false
THREAT_FEED_URLHAUS_URL=https://urlhaus-api.abuse.ch/v2/files/exports/{auth_key}/recent.csv
THREAT_FEED_URLHAUS_AUTH_KEY=

# Weekly candidate retraining. Requires a reviewed CSV with url,label and the
# optional [ml,train] dependencies. Candidate models are not auto-promoted.
MODEL_RETRAIN_SCHEDULER_ENABLED=false
MODEL_RETRAIN_INTERVAL_HOURS=168
MODEL_RETRAIN_DATASET_PATH=data/url_dataset.csv
MODEL_RETRAIN_ALGORITHMS=["lightgbm","random_forest","xgboost"]
MODEL_RETRAIN_TIMEOUT_SECONDS=7200

# Optional self-hosted MISP lookup and Telegram URL-scanner bot.
MISP_ENABLED=false
MISP_BASE_URL=https://127.0.0.1
MISP_API_KEY=
MISP_VERIFY_TLS=false
MISP_TIMEOUT_SECONDS=8
MISP_LOOKUP_LAST=90d
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=[]
TELEGRAM_TIMEOUT_SECONDS=10
# Local clone used by scripts/import_phishing_database.py.
THREAT_FEED_PHISHING_DATABASE_PATH=.aisec-data/Phishing.Database
# Secrets used only by docker-compose.urlvet.yml. Generate independent random
# values; do not expose Valkey or the URLVet API beyond loopback.
URLVET_CACHE_PASSWORD=
URLVET_ADMIN_JWT_SECRET=

# Distributed URL IOC telemetry. Give each managed machine its own API key,
# scoped only to telemetry:write; one API key contributes at most one consensus vote.
# Production must replace this with at least 32 random bytes.
TELEMETRY_SENSOR_PEPPER=dev-telemetry-pepper-change-in-production
TELEMETRY_RETENTION_DAYS=30
TELEMETRY_CONSENSUS_WINDOW_DAYS=14
TELEMETRY_MIN_INDEPENDENT_SENSORS=2
CORS_ALLOW_ORIGINS=["https://prewise.site","https://www.prewise.site","http://localhost:3000","http://127.0.0.1:3000"]

# SePay webhook + dynamic VietQR image. Account details are used only to generate the public QR.
# Prefer HMAC secret received from SePay; do not commit or expose it.
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_ACCOUNT=100876855977
SEPAY_BANK_NAME=VietinBank
SEPAY_ACCOUNT_NAME=
SEPAY_QR_BASE_URL=https://vietqr.app/img
SEPAY_PAYMENT_EXPIRY_MINUTES=30
SANDBOX_CREDIT_PRICE_VND=15000
SANDBOX_SESSION_MINUTES=10

# AWS disposable Windows sandbox. Prefer an account dedicated to untrusted workloads.
AWS_REGION=ap-southeast-1
AWS_SANDBOX_AMI_ID=
AWS_SANDBOX_INSTANCE_TYPE=t3.large
AWS_SANDBOX_SUBNET_ID=
AWS_SANDBOX_SECURITY_GROUP_ID=
AWS_SANDBOX_KEY_NAME=
AWS_SANDBOX_REMOTE_PORT=8443

# Production must set these values or the services will fail fast:
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://...
# DATABASE_AUTO_CREATE=false
# SEED_DEMO_USER=false
# API_KEY_PEPPER=<at-least-32-random-bytes>
# API_KEY=<random-secret>
# MCP_ALLOW_ANONYMOUS=false
# MCP_API_KEY_RATE_LIMIT_PER_MIN=120
