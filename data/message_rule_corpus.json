{
  "schema_version": "1",
  "purpose": "Synthetic offline regression corpus for email and SMS threat rules",
  "notes": [
    "Reserved .test domains are used; tests never visit malicious infrastructure.",
    "Cases encode behavior clusters, not single-keyword labels.",
    "Benign controls protect legitimate OTP, delivery and newsletter messages from regressions."
  ],
  "cases": [
    {
      "id": "email_hidden_destination_mismatch",
      "modality": "email",
      "text": "<a href=\"https://paypa1-verify.test/login\">https://paypal.com/security</a>",
      "metadata": {"subject": "Security notice", "sender": "PayPal <notice@gmail.com>"},
      "min_score": 0.85,
      "required_features": ["display_href_domain_mismatch", "embedded_url_risk"]
    },
    {
      "id": "email_disguised_executable_attachment",
      "modality": "email",
      "text": "Please review the attached invoice.",
      "metadata": {
        "subject": "Invoice",
        "sender": "Billing <billing@example.com>",
        "attachments": ["invoice.pdf.exe"]
      },
      "min_score": 0.85,
      "required_features": ["disguised_executable_attachment"]
    },
    {
      "id": "email_business_email_compromise",
      "modality": "email",
      "text": "CEO requests an urgent bank account change. Keep this confidential and wire the invoice payment today.",
      "metadata": {
        "subject": "Urgent payment",
        "sender": "CEO <ceo@gmail.com>",
        "reply_to": "finance@outside.test"
      },
      "min_score": 0.85,
      "required_features": ["business_email_compromise_cluster", "reply_to_domain_mismatch"]
    },
    {
      "id": "email_brand_spoof_authentication_failures",
      "modality": "email",
      "text": "Verify your Microsoft account now.",
      "metadata": {
        "subject": "Microsoft security alert",
        "sender": "Microsoft Support <notice@gmail.com>",
        "authentication_results": "spf=fail; dkim=fail; dmarc=fail"
      },
      "min_score": 0.85,
      "required_features": [
        "sender_brand_mismatch",
        "email_authentication_failure",
        "email_sender_spoofing_cluster"
      ]
    },
    {
