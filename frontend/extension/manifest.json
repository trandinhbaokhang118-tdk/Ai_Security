{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.2.0",
  "description": "__MSG_appDesc__",
  "default_locale": "vi",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*", "https://*/*"],
  "background": {"service_worker": "background.js", "type": "module"},
  "action": {"default_popup": "popup/popup.html", "default_title": "AI Security Armor", "default_icon": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}},
  "options_page": "options/options.html",
  "content_scripts": [
    {"matches": ["<all_urls>"], "js": ["content/page_scanner.js"], "run_at": "document_idle"},
    {"matches": ["https://mail.google.com/*"], "js": ["content/gmail_scanner.js"], "run_at": "document_idle"}
  ],
  "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}
}
