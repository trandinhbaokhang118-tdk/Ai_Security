{
    "manifest_version": 3,
    "name": "AI Security Armor",
    "version": "0.1.0",
    "description": "Lá chắn an ninh AI: đánh giá rủi ro URL và email tức thì, luôn kèm bằng chứng.",
    "default_locale": "vi",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "AI Security Armor",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/page_scanner.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://mail.google.com/*"
            ],
            "js": [
                "content/gmail_scanner.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}