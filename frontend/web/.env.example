# Chế độ API client cho Web App UI
#   mock = demo standalone
#   real = gọi Security Gateway production
NEXT_PUBLIC_API_MODE=real

# Domain chính thức
NEXT_PUBLIC_SITE_URL=https://prewise.site
NEXT_PUBLIC_API_BASE_URL=https://api.prewise.site
NEXT_PUBLIC_WS_BASE_URL=wss://api.prewise.site
NEXT_PUBLIC_MCP_URL=https://api.prewise.site/mcp
