# Chế độ API client cho Web App UI
#   mock = dùng MockApiClient (demo standalone, không cần backend)
#   real = dùng RealApiClient (gọi Security Gateway REST /v1/assess/* và WS /v1/chat)
NEXT_PUBLIC_API_MODE=mock

# URL gốc của Security Gateway (chỉ dùng khi NEXT_PUBLIC_API_MODE=real)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
