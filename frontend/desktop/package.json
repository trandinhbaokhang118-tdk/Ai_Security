{
  "name": "ai-security-armor-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Ứng dụng desktop AI Security Armor — Browser Cover",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "lucide-react": "^0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "concurrently": "latest",
    "cross-env": "latest",
    "typescript": "5.6.3",
    "wait-on": "latest"
  }
}
