# Sao chép thành .env.production và thay toàn bộ giá trị CHANGE_ME.
# Không commit file chứa secret.
POSTGRES_DB=armor
POSTGRES_USER=armor
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_32_CHARS
APP_ENV=production
LLM_BASE_URL=https://your-private-gpu-endpoint.example/v1
LLM_API_KEY=replace-with-a-long-random-secret
LLM_MODEL=prewise-security-v1
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOKENS=500
ADAPTER_REGISTRY_ENABLED=true
ADAPTER_MANIFEST_PATH=server/adapters/manifest.json
ADAPTER_BASE_URL=https://your-private-gpu-endpoint.example/v1
ADAPTER_API_KEY=replace-with-a-long-random-secret
ADAPTER_TIMEOUT_SECONDS=15
ADAPTER_MAX_RISK_CONTRIBUTION=0.25
PHONE_INTELLIGENCE_URL=
IP_GEOLOCATION_ENABLED=true
IP2LOCATION_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
IP2WHOIS_API_KEY=
WHOISXML_API_KEY=
IPQS_PHONE_API_KEY=
PHISHTANK_ENABLED=false
PHISHTANK_API_KEY=
URLVET_ENABLED=false
URLVET_API_URL=http://127.0.0.1:8080
MISP_ENABLED=false
MISP_BASE_URL=
MISP_API_KEY=
MISP_VERIFY_TLS=true
# Optional MetaDefender Cloud for quick EXE hash lookup and consented upload.
METADEFENDER_API_KEY=
METADEFENDER_BASE_URL=https://api.metadefender.com/v4
METADEFENDER_TIMEOUT_SECONDS=20
THREAT_FEED_SCHEDULER_ENABLED=false
THREAT_FEED_PHISHTANK_ENABLED=false
THREAT_FEED_OPENPHISH_ENABLED=false
THREAT_FEED_URLHAUS_ENABLED=false
THREAT_FEED_PHISHING_DATABASE_PATH=.aisec-data/Phishing.Database
TELEMETRY_SENSOR_PEPPER=replace-with-at-least-32-random-characters
TELEMETRY_MIN_INDEPENDENT_SENSORS=2
DATABASE_AUTO_CREATE=false
DATABASE_REQUIRE_TLS=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
SEED_DEMO_USER=false
API_KEY_PEPPER=CHANGE_ME_RANDOM_AT_LEAST_32_BYTES
API_KEY=CHANGE_ME_RANDOM_SERVICE_KEY
MCP_ALLOW_ANONYMOUS=false
# Include "null" so the packaged Electron renderer can call the shared Core API.
CORS_ALLOW_ORIGINS=["https://prewise.site","https://www.prewise.site","null"]
BACKEND_PORT=8000

# SePay QR checkout. Use HMAC-SHA256 in SePay; never commit the secret.
SEPAY_WEBHOOK_SECRET=CHANGE_ME_SEPAY_HMAC_SECRET
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NAME=
SEPAY_QR_BASE_URL=https://vietqr.app/img
SEPAY_PAYMENT_EXPIRY_MINUTES=30

# Khi dùng managed PostgreSQL, đặt DATABASE_REQUIRE_TLS=true và URL có:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/armor?sslmode=verify-full
# Anonymous/free server-side quotas
ANONYMOUS_DAILY_AI_CREDIT_LIMIT=5
ANONYMOUS_DAILY_DEEP_SCAN_LIMIT=1
# Email attachment security. docker-compose.production.yml supplies CLAMAV_HOST.
ATTACHMENT_SCAN_TIMEOUT_SECONDS=10
TESSERACT_LANGUAGES=vie+eng
ATTACHMENT_OCR_TIMEOUT_SECONDS=12
EMAIL_ATTACHMENT_SANDBOX_ENABLED=false
EMAIL_ATTACHMENT_ACTIVE_SCAN_LIMIT=12
EMAIL_OCR_IMAGE_LIMIT=5
EMAIL_SANDBOX_FILE_LIMIT=1
EMAIL_ATTACHMENT_BUDGET_SECONDS=35
EMAIL_ANALYSIS_TIMEOUT_SECONDS=90
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://api.prewise.site/v1/integrations/gmail/callback
GMAIL_TOKEN_ENCRYPTION_KEYS=
GMAIL_WEB_RETURN_URL=https://prewise.site/analyze?gmail=connected
GMAIL_API_TIMEOUT_SECONDS=12
